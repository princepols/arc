# Arc AI - Environment Variables

# Groq API Key (get from console.groq.com)
GEMINI_API_KEY=your_groq_api_key_here

# JWT Secret - change this to a long random string
JWT_SECRET=your_super_secret_jwt_key_change_this

# MySQL Database (XAMPP defaults)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=arc_ai
