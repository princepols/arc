{
  "root": "frontend",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/(?!.*\\.)(.*)",
      "dest": "/index.html",
      "status": 200
    }
  ]
}













